{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/server.js" },
    { "src": "/payment", "dest": "/server.js" },
    { "src": "/paymentresult", "dest": "/server.js" },
    { "src": "/webhook", "dest": "/server.js" },
    { "src": "/debug/env", "dest": "/server.js" },
    { "src": "/\\.well-known/(.*)", "dest": "/public/.well-known/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}