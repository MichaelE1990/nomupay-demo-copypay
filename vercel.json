{
  "version": 2,
  "routes": [
    { "src": "/",        "dest": "/server.js" },
    { "src": "/checkout", "dest": "/server.js" },
    { "src": "/result",   "dest": "/server.js" },
    { "src": "/\\.well-known/(.*)", "dest": "/public/.well-known/$1" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}