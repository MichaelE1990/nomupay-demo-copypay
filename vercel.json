{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/webhook", "methods": ["POST"], "dest": "/server.js" },
    { "src": "/webhooks/view", "dest": "/server.js" },
    { "src": "/debug/env", "dest": "/server.js" },
    { "src": "/paymentresult", "dest": "/server.js" },
    { "src": "/payment", "dest": "/server.js" },
    { "src": "/\\.well-known/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
